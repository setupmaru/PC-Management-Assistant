NODE_ENV=production

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/pc_assistant

# JWT secrets (minimum 32 characters in production)
JWT_ACCESS_SECRET=your-access-secret-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this

# Toss Payments
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=
TOSS_PLUS_PRICE=4900
TOSS_PRO_PRICE=15000

# Optional legacy Stripe integration
# STRIPE_SECRET_KEY=sk_live_...

# Public server URL and allowed browser origins
PUBLIC_BASE_URL=http://api.setupmaru.com:3400
ALLOWED_ORIGINS=http://api.setupmaru.com:3400

# Server bind address
PORT=3400
HOST=0.0.0.0
